SELECT 
    t.txnno AS transaction_id,
    t.txndate,
    c.firstname,
    c.lastname,
    p.productName,
    t.amount,
    t.spendby
FROM transactions t
INNER JOIN customers c 
    ON t.custno = c.custno
INNER JOIN products p 
    ON t.productno = p.productno
LIMIT 50;

	SELECT 
		t.txnno AS transaction_id,
		t.txndate,
		c.firstname,
		c.lastname,
		p.productName,
		t.amount,
		t.spendby
	FROM transactions t
	INNER JOIN customers c 
		ON t.custno = c.custno
	INNER JOIN products p 
		ON t.productno = p.productno
	WHERE c.isActive = 'Y'
	  AND p.isActive = 'Y'
	  AND t.amount IS NOT NULL
	  AND t.spendby IS NOT NULL LIMIT 100;
	  
	  
	  
	SELECT 
		t.txnno AS transaction_id,
		t.txndate,
		c.firstname,
		c.lastname,
		p.productName,
