create database retail;

use retail;

create table customers(custno int PRIMARY KEY,
 firstname varchar(20), lastname varchar(20),gender varchar(20), 
age int,profession varchar(20),contactNo long,
emailId varchar(20),
city varchar(20), state varchar(20),
isActive char(1),createdDate datetime, UpdatedDate datetime);

create table products(productno int PRIMARY KEY, productName varchar(20), Description varchar(20), isActive char(1),createdDate datetime, UpdatedDate datetime);

create table transactions(txnno int PRIMARY KEY, txndate datetime,
custno int, amount double,productno int, spendby varchar(10),
FOREIGN KEY (custno) REFERENCES customers(custno),
FOREIGN KEY (productno) REFERENCES products(productno) );

