public class RegistrationService{
	public void registerUser(int age) throws AgeNotEligibleException{
		if(age < 18)
		{
			throw new AgeNotFoundException("Age must be greater than 18");
		}
		System.out.println("User registered successfully");
	}
}

@RestController
@RequestMapping("/api/register")
public class RegistrationController{
	private final RegistrationService registrationService;
	
	@PostMapping
	public String register(@RequestParam int age)
	{
		return registrationService.regiterUser(age);
	}
}

@ControllerAdvice
public class GlobalExceptionHandler{
	@ExceptionHandler(AgeNotEligibleException.class)
    public ResponseEntity<String> handleAgeNotEligible(AgeNotEligibleException ex) {
        return new ResponseEntity<>("Registration failed: " + ex.getMessage(), HttpStatus.BAD_REQUEST);
    }
	
	@ExceptionHandler(Exception.class) // fallback for other exceptions
    public ResponseEntity<String> handleGeneral(Exception ex) {
        return new ResponseEntity<>("An error occurred: " + ex.getMessage(), HttpStatus.INTERNAL_SERVER_ERROR);
    }
}

